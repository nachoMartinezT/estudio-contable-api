# ============================================
# Guida Contable - Variables de Entorno
# ============================================
# Copiar este archivo a .env y completar los valores.
# NO versionar el archivo .env con credenciales reales.

# --------------------------------------------
# AFIP (Facturacion electronica)
# --------------------------------------------
# URL del servicio WSAA (autenticacion)
AFIP_WSAA_URL=https://wsaahomo.afip.gov.ar/ws/services/LoginCms
# URL del servicio WSFE (facturacion)
AFIP_WSFE_URL=https://wswhomo.afip.gov.ar/wsfev1/service.asmx
# Clave para encriptar passwords de certificados AFIP
AFIP_ENCRYPTION_KEY=<clave-segura-para-certificados>

# --------------------------------------------
# Comunicacion interna entre microservicios
# --------------------------------------------
# API Key compartida para endpoints /api/internal/
INTERNAL_API_KEY=<clave-segura-interna>

# --------------------------------------------
# Email (Resend)
# --------------------------------------------
# API Key de Resend para envio de emails
RESEND_API_KEY=re_<tu-api-key>

# --------------------------------------------
# Frontend
# --------------------------------------------
# URL base de la aplicacion frontend
APP_BASE_URL=http://localhost:5173

# --------------------------------------------
# MinIO (Object Storage S3-compatible)
# --------------------------------------------
# Usuario root de MinIO
MINIO_ROOT_USER=<usuario-minio>
# Password root de MinIO (minimo 8 caracteres)
MINIO_ROOT_PASSWORD=<password-minio>
# Endpoint interno (dentro de Docker)
MINIO_ENDPOINT=http://minio:9000
# Nombre del bucket para documentos
MINIO_BUCKET_DOCUMENTS=guida-documentos

# --------------------------------------------
# PostgreSQL (Base de datos principal)
# --------------------------------------------
# Usuario de PostgreSQL
DB_USER=<usuario-postgres>
# Password de PostgreSQL
DB_PASSWORD=<password-postgres>

# --------------------------------------------
# MongoDB (Base de datos de auditoria)
# --------------------------------------------
# Usuario root de MongoDB
MONGO_USER=<usuario-mongo>
# Password root de MongoDB
MONGO_PASSWORD=<password-mongo>

# --------------------------------------------
# JWT (Autenticacion)
# --------------------------------------------
# Secret para firma de tokens JWT (Base64-encoded, minimo 256 bits)
JWT_SECRET=<secret-base64-encoded>
